{
  "name": "@woby/three",
  "version": "0.2.94",
  "publishConfig": {
    "access": "public"
  },
  "description": "Woby Wrapper for ThreeJS",
  "main": "./dist/index.es.js",
  "module": "./dist/index.es.js",
  "browser": "./dist/woby3.umd.js",
  "unpkg": "./dist/woby3.umd.js",
  "jsdelivr": "./dist/woby3.umd.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "require": "./dist/index.es.js",
      "import": "./dist/index.es.js",
      "default": "./dist/woby3.umd.js"
    },
    "./jsx-runtime": {
      "import": "./dist/jsx-runtime.es.js",
      "require": "./dist/jsx-runtime.es.js",
      "default": "./dist/woby3.umd.js"
    },
    "./jsx-dev-runtime": {
      "import": "./dist/jsx-dev-runtime.es.js",
      "require": "./dist/jsx-dev-runtime.es.js",
      "default": "./dist/woby3.umd.js"
    },
    "./examples/fonts/*": "./examples/fonts/*",
    "./examples/jsm/*": "./examples/jsm/*",
    "./addons": "./examples/jsm/Addons.js",
    "./addons/*": "./examples/jsm/*",
    "./src/*": "./src/*",
    "./lib/*": "./lib/*",
    "./3": "./3/index.js",
    "./nodes": "./examples/jsm/nodes/*"
  },
  "scripts": {
    "bump": "pnpm version patch --no-git-tag-version",
    "push": "git push && git push --tags",
    "npmjs": "pnpm publish --access public",
    "commit": "pnpm git && pnpm bump && pnpm push",
    "release": "run-s -c commit npmjs",
    "declaration": "tsc --project tsconfig.json --declaration --declarationMap --emitDeclarationOnly --outDir ./lib --rootDir ./code --skipLibCheck || true",
    "declaration:watch": "tsc --build --force --declaration --emitDeclarationOnly --declarationMap  --verbose --watch",
    "watch": "vite build --watch",
    "build": "run-s clean:dist build:es build:umd declaration && pnpm bump",
    "build:es": "vite build",
    "build:umd": "vite build --config vite.config.umd.mts",
    "dev:only": "vite --config=vite.config.mts --force --mode dev --host",
    "dev": "run-p dev:only",
    "build:tsc": "tsc --build --force --declaration --declarationMap  --verbose",
    "watch:tsc": "tsc --build --force --declaration --declarationMap  --verbose --watch",
    "clean:3": "if exist 3 (rd 3 /s /q)",
    "clean:index": "(del index.* /q)",
    "clean:3types": "(del three-types.* /q)",
    "clean:dist": "if exist dist (rd dist /s /q)",
    "clean:examples": "if exist examples (rd examples /s /q)",
    "clean:jsx": "if exist jsx-runtime (rd jsx-runtime /s /q)",
    "clean:jsx:dev": "if exist jsx-dev-runtime (rd jsx-dev-runtime /s /q)",
    "clean:lib": "if exist lib (rd lib /s /q)",
    "clean:src": "if exist src (rd src /s /q)",
    "clean:3ts": "if exist 3.* (del 3.*)",
    "clean:3dts": "if exist 3.*.* (del 3.*.*)",
    "clean:dts": "if exist *.d.ts* (del *.d.ts*)",
    "comment": "do enable clean:3ts,clean:js, have to compile 2 times, ignore can't delete errors",
    "clean:all": "run-p clean:index clean:3types clean:3 clean:dist clean:examples clean:jsx clean:jsx:dev clean:lib clean:src clean:3ts clean:3dts clean:dts clean:js",
    "release:automatic": "semantic-release --extends ../semantic-release.config.js",
    "commit:help": "echo 'Usage: pnpm run commit' && echo 'This will start the commitizen wizard to create a conventional commit.' && echo 'Follow the prompts to enter commit type, scope, and message.'",
    "test": "tsx test/three.test.ts && tsx test/controls.test.ts && tsx test/geometries.test.ts && tsx test/lines.test.ts && tsx test/math.test.ts && tsx test/misc.test.ts && tsx test/effects.test.ts && tsx test/postprocessing.test.ts && tsx test/renderers.test.ts && tsx test/objects.test.ts && tsx test/helpers.test.ts && tsx test/modifiers.test.ts && tsx test/loaders.test.ts && tsx test/jsx.test.tsx",
    "test:e2e": "playwright test",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [
    "jasmine",
    "threejs",
    "woby"
  ],
  "author": "Tan Jee Han",
  "license": "MIT",
  "devDependencies": {
    "3d-tiles-renderer": "^0.4.28",
    "@playwright/test": "^1.60.0",
    "@rollup/plugin-alias": "^6.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "madge": "^8.0.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1",
    "web-ifc-three": "^0.0.126"
  },
  "peerDependencies": {
    "@types/three": "^0.173.0",
    "@woby/use": "workspace:../use",
    "three": "^0.173.0",
    "woby": "workspace:../woby"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@three.ez/batched-mesh-extensions": "^0.0.11",
    "@three.ez/simplify-geometry": "^0.0.1",
    "postcss": "^8.5.15",
    "three-mesh-bvh": "^0.9.10"
  }
}
