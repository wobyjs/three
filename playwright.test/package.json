{
    "name": "@woby/three-playwright-tests",
    "version": "1.0.0",
    "description": "Playwright tests for @woby/three components",
    "type": "module",
    "scripts": {
        "test": "playwright test",
        "test:ui": "playwright test --ui",
        "test:report": "playwright show-report",
        "test:debug": "playwright test --debug",
        "test:list": "playwright test --reporter=list"
    },
    "keywords": [
        "playwright",
        "testing",
        "three.js",
        "woby"
    ],
    "author": "Test Engineer",
    "license": "MIT",
    "dependencies": {
        "@anthropic-ai/sdk": "^0.56.0",
        "@woby/three": "workspace:..",
        "sharp": "^0.33.0",
        "woby": "workspace:../../woby"
    },
    "devDependencies": {
        "@playwright/test": "^1.56.1",
        "@types/node": "^24.10.1"
    }
}